@page
@model ITGSA.Frontend.Pages.Consultas.ResumenPagosModel
@{
    ViewData["Title"] = "Resumen de Ingresos por Banco";
}

<div class="container mt-4">
    <h2>Consultar Ingresos por Banco</h2>
    <hr />

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="mes" class="form-label">Mes:</label>
                    <select class="form-control" id="mes" name="mes">
                        @for (int i = 1; i <= 12; i++)
                        {
                            var mesNombre = new DateTime(2024, i, 1).ToString("MMMM");
                            <option value="@i" selected="@(Model.Mes == i)">@mesNombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="anio" class="form-label">Año:</label>
                    <select class="form-control" id="anio" name="anio">
                        @for (int i = 2023; i <= DateTime.Now.Year; i++)
                        {
                            <option value="@i" selected="@(Model.Anio == i)">@i</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">Consultar</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.DatosGrafica != null && Model.DatosGrafica.Any() && Model.Bancos != null && Model.Bancos.Any())
    {
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4>Mes elegido: @Model.MesElegido</h4>
                <p class="mb-0">(Últimos 3 meses de forma descendente)</p>
            </div>
            <div class="card-body">
                <canvas id="ingresosChart" width="800" height="400"></canvas>
                <hr />
                
                <div class="table-responsive mt-4">
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Mes</th>
                                @foreach (var banco in Model.Bancos)
                                {
                                    <th class="text-center">@banco</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.DatosGrafica.Count; i++)
                            {
                                <tr>
                                    <td><strong>@Model.NombresMeses[i]</strong></td>
                                    @foreach (var banco in Model.Bancos)
                                    {
                                        decimal valor = 0;
                                        if (Model.DatosGrafica[i].ContainsKey(banco))
                                        {
                                            valor = Model.DatosGrafica[i][banco];
                                        }
                                        <td class="text-center">@valor.ToString("N2")</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer">
                <button id="btnPdf" class="btn btn-danger">📄 Generar PDF</button>
            </div>
        </div>
    }
    else if (Model.Mes > 0)
    {
        <div class="alert alert-warning">
            No hay datos de ingresos para el período seleccionado.
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Convertir los datos de C# a JavaScript de forma segura
        var bancos = @Html.Raw(Json.Serialize(Model.Bancos));
        var datosGrafica = @Html.Raw(Json.Serialize(Model.DatosGrafica));
        var labels = @Html.Raw(Json.Serialize(Model.NombresMeses));
        
        if (bancos && bancos.length > 0 && datosGrafica && datosGrafica.length > 0 && labels && labels.length > 0) {
            const ctx = document.getElementById('ingresosChart').getContext('2d');
            const datasets = [];
            
            // Colores para cada banco
            const colores = [
                'rgba(54, 162, 235, 0.7)',
                'rgba(255, 99, 132, 0.7)',
                'rgba(255, 206, 86, 0.7)',
                'rgba(75, 192, 192, 0.7)',
                'rgba(153, 102, 255, 0.7)',
                'rgba(255, 159, 64, 0.7)'
            ];
            
            for (let i = 0; i < bancos.length; i++) {
                const datosBanco = [];
                for (let j = 0; j < labels.length; j++) {
                    let valor = 0;
                    if (datosGrafica[j] && datosGrafica[j][bancos[i]]) {
                        valor = datosGrafica[j][bancos[i]];
                    }
                    datosBanco.push(valor);
                }
                
                datasets.push({
                    label: bancos[i],
                    data: datosBanco,
                    backgroundColor: colores[i % colores.length],
                    borderColor: colores[i % colores.length].replace('0.7', '1'),
                    borderWidth: 1
                });
            }
            
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Ingresos (Q)'
                            },
                            ticks: {
                                callback: function(value) {
                                    return 'Q. ' + value.toFixed(2);
                                }
                            }
                        },
                        x: {
                            title: {
                                display: true,
                                text: 'Mes'
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': Q. ' + context.raw.toFixed(2);
                                }
                            }
                        },
                        legend: {
                            position: 'top'
                        }
                    }
                }
            });
        }
        
        document.getElementById('btnPdf')?.addEventListener('click', function() {
            window.print();
        });
    </script>
}